# YouTube Mod Monitor — Environment Variables
# Copy this file to .env and fill in your values

# -------------------------------------------------------
# REQUIRED: Your Google OAuth 2.0 Client ID
# 1. Go to https://console.cloud.google.com/
# 2. APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized JavaScript origins: http://localhost:5173
# 5. Enable "YouTube Data API v3" in your project
# -------------------------------------------------------
VITE_GOOGLE_CLIENT_ID=620740249854-sm4gsapnbsbsi903f6ra9g1d2isrnar4.apps.googleusercontent.com

# -------------------------------------------------------
# REQUIRED FOR DATABASE: Supabase URL and Anon Key
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy the URL and "anon" public key
# -------------------------------------------------------
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
